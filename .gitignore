# dotnet local tools
.dotnet/
.tools/

# Package Manager Console / NuGet
packages/
*.nupkg
*.snupkg

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Database / EF Core migrations snapshots (optional – keep only code)
# If you want to exclude migrations designer.cs files, uncomment:
# **/Migrations/*.Designer.cs
# But better to keep them – so not excluded.

# Hangfire SQL Server database (if stored in project folder)
*.hangfire.db
hangfire.mdf
hangfire_log.ldf

# Uploaded files (keep the folder, ignore its contents)
wwwroot/uploads/
!wwwroot/uploads/.gitkeep

# Logs
logs/
*.log
*.logs

# Generated documentation
docs/_site/
docs/api/

# Environment / secrets
appsettings.Development.json
appsettings.Production.json
secrets.json
*.secrets.json
.env
*.local.*

# Launch profiles (user-specific)
Properties/launchSettings.json

# Blazor / WebAssembly
**/wwwroot/_framework/
**/wwwroot/css/bootstrap/
**/wwwroot/lib/
**/bin/Release/
**/obj/Release/

# Node (if any frontend tooling)
node_modules/
npm-debug.log
yarn-error.log

# OS junk
.DS_Store
Thumbs.db
*.bak
*.orig
*~

# Rider / VS Code
*.code-workspace
.vscode/